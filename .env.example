# ---- Base de datos PostgreSQL ----
# Railway provee DATABASE_URL automáticamente al agregar el plugin PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/fitvang?sslmode=require

# ---- JWT ----
# Generar con: openssl rand -base64 48
JWT_SECRET=cambia-esto-en-prod
JWT_REFRESH_SECRET=cambia-esto-tambien

# ---- Wompi (Colombia) ----
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_PRIVATE_KEY=prv_test_xxx
WOMPI_EVENT_SECRET=test_event_secret
WOMPI_SANDBOX=true

# ---- Web Push (VAPID) ----
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@fitvang.com

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxx
FROM_EMAIL=no-reply@fitvang.com

# ---- App ----
# URL pública del frontend en Vercel (para CORS)
PUBLIC_APP_URL=https://fitvang.vercel.app
APP_TIMEZONE=America/Bogota

# ---- Cron Jobs (Vercel Cron) ----
# Generar con: openssl rand -hex 32
# Debe coincidir con el valor en Vercel → Settings → Environment Variables
CRON_SECRET=cambia-esto-en-prod

# ---- Alertas operacionales (Discord o Telegram) ----
# Discord: Webhook URL del canal de alertas (Server → Integrations → Webhooks)
# Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage (adaptar en api/index.ts)
ALERT_WEBHOOK_URL=

# ---- Seed inicial (opcional) ----
SEED_SUPER_ADMIN_EMAIL=admin@fitvang.com
SEED_SUPER_ADMIN_PASSWORD=Fitvang2026!
SEED_SUPER_ADMIN_DOCUMENTO=00000000
